rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "saifulalammasudmn@gmail.com" && request.auth.token.email_verified == true) || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')));
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Diary Rules
    match /diaries/{diaryId} {
      // Students can read all diaries without login
      allow read: if true;
      // Only admins/teachers can write diaries
      allow create, update, delete: if isAdmin();
    }

    // Math Quiz Rules
    match /math_quizzes/{quizId} {
      // Students can read all math quizzes without login
      allow read: if true;
      // Only admins/teachers can write math quizzes
      allow create, update, delete: if isAdmin();
    }

    // Bangla Section Rules
    match /bangla_poems/{poemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bangla_conjuncts/{conjunctId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Student Rules
    match /students/{studentId} {
      allow read: if true; // Allow reading for login verification
      allow create, update, delete: if isAdmin();
    }

    // Routine Rules
    match /routines/{routineId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // MCQ Rules
    match /mcqs/{mcqId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Formula Rules
    match /formulas/{formulaId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.authorId);
    }

    // Writing Content Rules
    match /writing_content/{contentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.authorId);
    }

    // Class Settings Rules
    match /class_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // English Rhymes Rules
    function isValidRhyme(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             (!('videoUrl' in data) || (data.videoUrl is string && (data.videoUrl.matches("^https://.*") || data.videoUrl == ""))) &&
             data.authorId is string &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    match /english_rhymes/{rhymeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidRhyme(request.resource.data);
      allow update: if isAdmin() && isValidRhyme(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "saifulalammasudmn@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')));
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Diary Rules
    match /diaries/{diaryId} {
      // Students can read all diaries without login
      allow read: if true;
      // Only admins/teachers can write diaries
      allow create, update, delete: if isAdmin();
    }

    // Math Quiz Rules
    match /math_quizzes/{quizId} {
      // Students can read all math quizzes without login
      allow read: if true;
      // Only admins/teachers can write math quizzes
      allow create, update, delete: if isAdmin();
    }

    // Bangla Section Rules
    match /bangla_poems/{poemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bangla_conjuncts/{conjunctId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
